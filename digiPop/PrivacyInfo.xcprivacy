<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The app shows ads via Google Mobile Ads, which can use data for tracking. -->
	<key>NSPrivacyTracking</key>
	<true/>
	<!-- Intentionally empty. Google does not publish a tracking-domain list and
	     the Google Mobile Ads SDK's own manifest ships no NSPrivacyTrackingDomains;
	     the tracking disclosure rides on the SDK's DeviceID (tracking=true) entry.
	     Empty is the Google-supported value and passes App Store review. -->
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<!-- Intentionally empty. The Google Mobile Ads SDK declares all collected data
	     types in its own bundled manifest (Apple merges manifests at submission),
	     and digiPop's own code transmits nothing beyond local UserDefaults.
	     The matching App Store Connect "App Privacy" questionnaire still must be
	     completed by hand (Device ID, Advertising Data, Product Interaction,
	     Coarse Location, Crash/Performance/Diagnostic data — per AdMob's data
	     disclosure docs). -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<!-- Required-reason API usage by the app's own code. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- UserDefaults: GameProgress + SettingsManager store the player's
			     own progress and preferences, read back only by this app. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
