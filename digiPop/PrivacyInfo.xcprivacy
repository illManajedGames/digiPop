<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- False at the app level: digiPop's own first-party code performs no tracking
	     and connects to no tracking domains. The Google Mobile Ads SDK declares its
	     own tracking (NSPrivacyTracking + DeviceID tracking=true) and domains in its
	     bundled manifest, which Apple merges at submission.
	     Apple's validator requires: NSPrivacyTracking=false => NSPrivacyTrackingDomains
	     MUST be empty (and true => MUST be non-empty). Keep these consistent. -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<!-- Intentionally empty. The Google Mobile Ads SDK declares all collected data
	     types in its own bundled manifest (Apple merges manifests at submission),
	     and digiPop's own code transmits nothing beyond local UserDefaults.
	     The matching App Store Connect "App Privacy" questionnaire still must be
	     completed by hand (Device ID, Advertising Data, Product Interaction,
	     Coarse Location, Crash/Performance/Diagnostic data — per AdMob's data
	     disclosure docs). -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<!-- Required-reason API usage by the app's own code. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- UserDefaults: GameProgress + SettingsManager store the player's
			     own progress and preferences, read back only by this app. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
